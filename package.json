{
  "name": "@manuscripts/article-editor",
  "version": "4.13.41-LEAN-5586.0",
  "license": "CPAL-1.0",
  "description": "React components for editing and viewing manuscripts",
  "repository": "github:Atypon-OpenSource/manuscripts-article-editor",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "main": "dist/cjs",
  "module": "dist/es",
  "types": "dist/types",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "npm-run-all2 --parallel 'build:* --watch'",
    "build": "npm-run-all2 --parallel build:*",
    "build:cjs": "tsc --outDir dist/cjs --module commonjs",
    "build:es": "tsc --outDir dist/es --declarationDir dist/types --declaration",
    "test": "TZ=UTC jest --runInBand --detectOpenHandles --forceExit",
    "lint": "eslint src types --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src types --ext .ts,.tsx --max-warnings 0 --fix",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write \"{src,stories,tests}/**/*.{js,ts,tsx,css}\"",
    "preversion": "npm-run-all2 --parallel typecheck lint build",
    "prepare": "husky",
    "version": "pnpm build",
    "unlink-all": "rm pnpm-workspace.yaml && pnpm install"
  },
  "dependencies": {
    "@fontsource/lato": "5.2.5",
    "@fontsource/pt-sans": "5.2.5",
    "@fontsource/pt-serif": "5.2.5",
    "@headlessui/react": "2.2.3",
    "@manuscripts/body-editor": "3.12.46-LEAN-5586.2",
    "@manuscripts/style-guide": "3.5.22-LEAN-5586.0",
    "@manuscripts/track-changes-plugin": "2.3.11-LEAN-5586.0",
    "@manuscripts/transform": "4.3.43-LEAN-5586.3",
    "@popperjs/core": "2.11.8",
    "axios": "1.16.0",
    "date-fns": "4.1.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "3.4.3",
    "html-react-parser": "5.2.5",
    "jwt-decode": "4.0.0",
    "lodash": "4.18.1",
    "prosemirror-model": "1.25.0",
    "prosemirror-state": "1.4.3",
    "prosemirror-transform": "1.10.4",
    "prosemirror-utils": "1.2.2",
    "prosemirror-view": "1.41.0",
    "react": "19.2.6",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.2.6",
    "react-is": "18.3.1",
    "react-popper": "2.3.0",
    "react-router-dom": "6.30.0",
    "react-select": "5.10.2",
    "styled-components": "5.3.11",
    "use-sync-external-store": "1.6.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.1",
    "@manuscripts/eslint-config": "0.5.1",
    "@types/csl": "npm:csl-json@v0.1.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "20.17.46",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "5.1.36",
    "@types/use-sync-external-store": "1.5.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "babel-jest": "30.4.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-diff": "2.1.7",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
